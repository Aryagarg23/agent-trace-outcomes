{
  "name": "agent-trace-outcomes",
  "version": "0.1.0",
  "description": "Outcome Records for Agent Trace — an additive extension that records the verified outcome of code changes: which checks ran, the results, who reviewed it, and what lesson was learned.",
  "keywords": [
    "agent-trace",
    "ai",
    "attribution",
    "verification",
    "outcome",
    "provenance",
    "git"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aryagarg23/agent-trace-outcomes.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "atrace-outcomes": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    }
  },
  "files": [
    "dist",
    "schemas.ts",
    "SPEC.md",
    "AGENTS.md",
    "action.yml"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
